# Alma API Configuration
# Get your API key from Alma Developer Network: https://developers.exlibrisgroup.com/
ALMA_API_KEY=your_alma_api_key_here
ALMA_API_BASE_URL=https://api-na.hosted.exlibrisgroup.com

# LiteLLM Configuration
# Configure your LLM API endpoint and key
LITELLM_API_KEY=your_litellm_api_key_here
LITELLM_BASE_URL=https://ai-gateway.andrew.cmu.edu
LITELLM_MODEL=gpt-5

# Application Configuration
# Generate a secure random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_for_flask_sessions_here

# Flask Environment (development or production)
# Set to 'production' when deploying to production
FLASK_ENV=development
