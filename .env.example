# License Uploader Configuration Template
# Copy this file to .env and fill in your actual values

# Flask Configuration
FLASK_SECRET_KEY=your-secret-key-here-change-to-random-string
FLASK_ENV=development

# LiteLLM API Configuration
# Get your API key from: https://litellm.ai/
LITELLM_API_KEY=your-litellm-api-key-here

# Ex Libris Alma API Configuration
# Get your API key from: Alma Configuration > General > API
ALMA_API_KEY=your-alma-api-key-here

# Alma API Base URL (change based on your region)
# North America: https://api-na.hosted.exlibrisgroup.com
# Europe: https://api-eu.hosted.exlibrisgroup.com
# Asia Pacific: https://api-ap.hosted.exlibrisgroup.com
ALMA_API_BASE_URL=https://api-na.hosted.exlibrisgroup.com

# LLM Model Selection (optional)
# Options: gpt-4, gpt-3.5-turbo, claude-3-opus, etc.
# Default: gpt-4
LLM_MODEL=gpt-4

# Server Configuration (optional)
# Port to run on (default: 5000)
FLASK_RUN_PORT=5000

# Rate Limiting Storage (optional)
# Options: memory://, redis://localhost:6379
RATE_LIMIT_STORAGE_URI=memory://

# Debug Mode (NEVER set to True in production!)
DEBUG=False
